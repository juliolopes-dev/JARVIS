# Banco
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/jarvis

# Timezone
TZ=America/Sao_Paulo

# Autenticacao
JWT_SECRET=chave_secreta_minimo_32_caracteres
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=600
JWT_REFRESH_EXPIRES_DAYS=30

# Servidor
PORT=8000
ENVIRONMENT=production

# Frontend / CORS
FRONTEND_URL=https://jarvis.seudominio.com.br
CORS_ORIGINS=["https://jarvis.seudominio.com.br"]

# Redis
REDIS_URL=redis://default:senha@host:6379

# Logs
LOG_LEVEL=info

# APIs de IA
DEEPSEEK_API_KEY=sk-...
# OpenAI usado apenas para Whisper (transcricao) e embeddings
OPENAI_API_KEY=sk-...
# Admin key (opcional) — usada apenas para /api/custos/* ler usage real da OpenAI
# Pegar em https://platform.openai.com/settings/organization/admin-keys
OPENAI_ADMIN_KEY=sk-admin-...
# Anthropic (opcional — nao usado no cerebro principal)
ANTHROPIC_API_KEY=sk-ant-...

# Mem0
MEM0_COLLECTION_NAME=jarvis_memories

# ElevenLabs (Fase 5)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Web Push (Fase 3)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=

# WhatsApp via Evolution API (Modo 1 — Observador)
# Documentacao: https://doc.evolution-api.com/v2
# Modo 1 nao envia mensagens — apenas observa contatos com flg_monitorar_whatsapp=true
EVOLUTION_API_URL=https://evolution.seudominio.com.br
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=jarvis
# Validacao do webhook recebido — geralmente igual a EVOLUTION_API_KEY
EVOLUTION_WEBHOOK_SECRET=
# Kill switch — false desabilita toda a integracao
WHATSAPP_ENABLED=false
